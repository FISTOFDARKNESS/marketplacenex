datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String        @id @default(uuid())
  username       String        @unique
  email          String        @unique
  passwordHash   String
  balance        Float         @default(0)
  role           String        @default("user")
  robloxId       BigInt?
  robloxUsername String?
  robloxCookie   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  purchases      Transaction[] @relation("BuyerTransactions")
  sales          Transaction[] @relation("SellerTransactions")
  wishlist       Wishlist[]
  withdrawals    Withdrawal[]
  deposits       DepositOrder[]
  inventory       UserItem[]
  recipientOrders Order[] @relation("RecipientOrders")
  buyerOrders     Order[] @relation("BuyerOrders")
  verifications   RobloxVerification[]
}

model Item {
  id             String        @id @default(uuid())
  robloxAssetId  BigInt        @unique
  name           String
  category       String
  rarity         String
  rap            Int
  rapLabel       String
  price          Float
  img            String
  size           String
  demand         Int           @default(-1)
  trend          Int           @default(-1)
  createdAt      DateTime      @default(now())
  transactions   Transaction[]
  wishlist       Wishlist[]
  userItems      UserItem[]
  orders         Order[]
}

model Transaction {
  id        String   @id @default(uuid())
  buyerId   String
  buyer     User     @relation("BuyerTransactions", fields: [buyerId], references: [id])
  sellerId  String
  seller    User     @relation("SellerTransactions", fields: [sellerId], references: [id])
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id])
  price     Float
  status    String   @default("COMPLETED")
  createdAt DateTime @default(now())
}

model RobloxVerification {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  robloxUsername String
  robloxId       BigInt?
  phrase         String
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model UserItem {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id])
  createdAt DateTime @default(now())
}

model Order {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation("RecipientOrders", fields: [userId], references: [id])
  buyerId    String?
  buyer      User?    @relation("BuyerOrders", fields: [buyerId], references: [id])
  itemId     String
  item       Item     @relation(fields: [itemId], references: [id])
  robloxUser String
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Seller {
  id        String   @id @default(uuid())
  displayId String   @unique
  name      String
  markup    Float    @default(0)
  createdAt DateTime @default(now())
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, itemId])
}

model Withdrawal {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  amount    Int
  queuePos  Int      @default(10000)
  type      String   @default("receber")
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DepositOrder {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  usdAmount     Float
  robuxAmount   Int
  paymentMethod String
  paymentUrl    String?
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
